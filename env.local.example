# Скопируйте этот файл в .env.local и подставьте значения из
# Supabase Dashboard → Project Settings → API.
# .env.local уже в .gitignore — сюда безопасно вставлять anon key (он публичный по дизайну Supabase).

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
